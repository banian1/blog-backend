# MySQL 配置
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=blog_db
MYSQL_USER=blog_user
MYSQL_PASSWORD=blog_password123

# Spring Boot 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/blog_db?useSSL=false&serverTimezone=UTC&characterEncoding=utf-8
SPRING_DATASOURCE_USERNAME=blog_user
SPRING_DATASOURCE_PASSWORD=blog_password123

# Spring Boot 服务配置
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
